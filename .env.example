# --- Driftläge ---
# test  = mock-BankID, in-memory DAL, ingen extern beroende
# live  = riktig BankID via Signicat + Supabase
APP_MODE=test

# --- Public app URL (krävs i live för Signicat callback) ---
NEXT_PUBLIC_APP_URL=https://concent.usha.se

# --- Supabase (krävs när APP_MODE=live) ---
SUPABASE_URL=https://fkotofxvqiqblxusixqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Signicat (krävs när APP_MODE=live) ---
# Hämta från Signicat dashboard efter onboarding-flödet är klart.
# Se ~/.claude/projects/-Users-pabloacosta/memory/project_signicat_contract.md
SIGNICAT_CLIENT_ID=
SIGNICAT_CLIENT_SECRET=
SIGNICAT_ACCOUNT_ID=
SIGNICAT_API_BASE=https://api.signicat.com

# --- HMAC-secret för cookie-signering + personnummer-hashning ---
# Generera med: openssl rand -base64 32
# RYM ALDRIG denna i klartext i kod eller logs.
PNO_HMAC_SECRET=

# --- Stripe (krävs när APP_MODE=live) ---
# Skapa nycklar i https://dashboard.stripe.com/apikeys
# Test-nycklar OK för dev, byt till live-nycklar vid public launch
STRIPE_SECRET_KEY=
# Webhook secret från https://dashboard.stripe.com/webhooks (för signature-verifiering)
STRIPE_WEBHOOK_SECRET=
# Pris i öre. 5000 = 50 kr per samtycke (avsändare betalar)
STRIPE_PRICE_SEK=5000

# --- Konfiguration ---
# Antal timmar mellan signering och aktivering (default: 72h = 3 dagar)
CONSENT_DELAY_HOURS=72
