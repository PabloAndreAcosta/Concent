# --- Driftläge ---
# test  = mock-BankID, in-memory DAL, ingen extern beroende
# live  = riktig BankID + Supabase
APP_MODE=test

# --- Supabase (krävs när APP_MODE=live) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- BankID (krävs när APP_MODE=live) ---
# Sökväg till test-cert (.p12) från BankID + lösenord
BANKID_CERT_PATH=./certs/bankid.p12
BANKID_CERT_PASSWORD=
BANKID_API_URL=https://appapi2.test.bankid.com/rp/v6.0

# --- Konfiguration ---
# Antal timmar mellan signering och aktivering (default: 72h = 3 dagar)
CONSENT_DELAY_HOURS=72
